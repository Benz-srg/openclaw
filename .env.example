# openclaw - Environment Variables
# Copy this file to .env and fill in your actual values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# DB 1: Read-Only Supabase (market_data source)
SUPABASE_DATA_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_DATA_KEY=your_supabase_data_anon_or_service_key

# DB 2: Write-Only Supabase (indicators destination)
SUPABASE_INDICATOR_URL=https://yyyyyyyyyyyy.supabase.co
SUPABASE_INDICATOR_KEY=your_supabase_indicator_service_key
